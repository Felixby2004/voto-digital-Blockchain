# DATABASE
DATABASE_URL="postgresql://admin:password@localhost:5432/universidad_voto?schema=public"

# SYSCOIN NEVM (Blockchain)
SYSCOIN_RPC_URL="https://rpc.syscoin.org"
SYSCOIN_CHAIN_ID=57
CONTRACT_ADDRESS="0x..."

# RELAYER & MIXNET
RELAYER_PORT=3012
MIXNET_NODES="node1,node2,node3"

# ADMIN MFA
ADMIN_MFA_SECRET="base32_secret_key"

# FRONTEND
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXT_PUBLIC_WS_URL="ws://localhost:3000"

# GATEWAY
GATEWAY_PORT=3000
CORS_ORIGIN=http://localhost:3001,http://localhost:3002
NODE_ENV=development

# AUTH SERVICE
AUTH_PORT=3001
JWT_SECRET=supersecretjwtkey_change_me_production
JWT_REFRESH_SECRET=supersecretrefreshkey_change_me_production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# PADRÓN SERVICE
PADRON_PORT=3005